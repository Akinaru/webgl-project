{
  "dialogues": {
    "bloom.intro": {
      "key": "bloom.intro",
      "once": true,
      "startNode": "intro_1",
      "nodes": {
        "intro_1": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Salut. Je suis Bloom, la petite goutte qui va te guider.",
          "next": "intro_2"
        },
        "intro_2": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Ton role va evoluer selon tes choix. On commence ?",
          "next": "role_choice"
        },
        "role_choice": {
          "type": "choice",
          "speaker": "Bloom",
          "text": "Quelle approche te ressemble le plus ?",
          "choices": [
            {
              "id": "inventeur",
              "text": "J observe, je teste, j invente.",
              "actions": [
                {
                  "type": "addMetier",
                  "metier": "INVENTEUR",
                  "amount": 3
                },
                {
                  "type": "setFlag",
                  "key": "bloom_role",
                  "value": "inventeur"
                }
              ],
              "next": "inventeur_reply"
            },
            {
              "id": "meneur",
              "text": "Je prends les decisions et je motive.",
              "actions": [
                {
                  "type": "addMetier",
                  "metier": "MENEUR",
                  "amount": 3
                },
                {
                  "type": "setFlag",
                  "key": "bloom_role",
                  "value": "meneur"
                }
              ],
              "next": "meneur_reply"
            },
            {
              "id": "travailleur",
              "text": "Je fonce et j execute proprement.",
              "actions": [
                {
                  "type": "addMetier",
                  "metier": "TRAVAILLEUR",
                  "amount": 3
                },
                {
                  "type": "setFlag",
                  "key": "bloom_role",
                  "value": "travailleur"
                }
              ],
              "next": "travailleur_reply"
            },
            {
              "id": "botaniste",
              "text": "Je protege le vivant et je cultive.",
              "actions": [
                {
                  "type": "addMetier",
                  "metier": "BOTANISTE",
                  "amount": 3
                },
                {
                  "type": "setFlag",
                  "key": "bloom_role",
                  "value": "botaniste"
                }
              ],
              "next": "botaniste_reply"
            }
          ]
        },
        "inventeur_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil inventeur active.",
          "next": "mission_offer"
        },
        "meneur_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil meneur active.",
          "next": "mission_offer"
        },
        "travailleur_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil travailleur active.",
          "next": "mission_offer"
        },
        "botaniste_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil botaniste active.",
          "next": "mission_offer"
        },
        "mission_offer": {
          "type": "choice",
          "speaker": "Bloom",
          "text": "Je peux declencher le mini-jeu de calibration. On y va ?",
          "choices": [
            {
              "id": "yes",
              "text": "Oui, lance-le.",
              "actions": [
                {
                  "type": "setFlag",
                  "key": "calibration_requested",
                  "value": true
                },
                {
                  "type": "startMiniGame",
                  "key": "calibration.v1"
                }
              ],
              "next": "mission_yes"
            },
            {
              "id": "no",
              "text": "Pas maintenant.",
              "actions": [
                {
                  "type": "setFlag",
                  "key": "calibration_requested",
                  "value": false
                }
              ],
              "next": "mission_no"
            }
          ]
        },
        "mission_yes": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Top. Je te laisse la main, je surveille les variables.",
          "next": "bonus_branch"
        },
        "mission_no": {
          "type": "line",
          "speaker": "Bloom",
          "text": "D accord. On continue la narration tranquille.",
          "next": "bonus_branch"
        },
        "bonus_branch": {
          "type": "branch",
          "branches": [
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "inventeur"
                }
              ],
              "next": "bonus_inventeur"
            },
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "meneur"
                }
              ],
              "next": "bonus_meneur"
            },
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "travailleur"
                }
              ],
              "next": "bonus_travailleur"
            },
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "botaniste"
                }
              ],
              "next": "bonus_botaniste"
            }
          ],
          "fallbackNext": "bonus_default"
        },
        "bonus_inventeur": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus inventeur: +1 botaniste pour l equilibre.",
          "actions": [
            {
              "type": "addMetier",
              "metier": "BOTANISTE",
              "amount": 1
            }
          ],
          "next": "end"
        },
        "bonus_meneur": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus meneur: +1 travailleur pour concretiser.",
          "actions": [
            {
              "type": "addMetier",
              "metier": "TRAVAILLEUR",
              "amount": 1
            }
          ],
          "next": "end"
        },
        "bonus_travailleur": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus travailleur: +1 meneur pour la coordination.",
          "actions": [
            {
              "type": "addMetier",
              "metier": "MENEUR",
              "amount": 1
            }
          ],
          "next": "end"
        },
        "bonus_botaniste": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus botaniste: +1 inventeur pour optimiser le vivant.",
          "actions": [
            {
              "type": "addMetier",
              "metier": "INVENTEUR",
              "amount": 1
            }
          ],
          "next": "end"
        },
        "bonus_default": {
          "type": "line",
          "speaker": "Bloom",
          "text": "On garde une base neutre pour le moment.",
          "next": "end"
        },
        "end": {
          "type": "end",
          "actions": [
            {
              "type": "setFlag",
              "key": "bloom_intro_done",
              "value": true
            },
            {
              "type": "setHudHint",
              "text": "Dialogue termine. Clique dans la scene pour reprendre le controle."
            }
          ]
        }
      }
    },
    "bloom.followup": {
      "key": "bloom.followup",
      "once": false,
      "startNode": "f1",
      "nodes": {
        "f1": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Petit point d etape: tu peux me reparler quand tu veux.",
          "next": "f2"
        },
        "f2": {
          "type": "choice",
          "speaker": "Bloom",
          "text": "Tu veux quoi maintenant ?",
          "choices": [
            {
              "id": "train",
              "text": "Un mini entrainement",
              "actions": [
                {
                  "type": "startMiniGame",
                  "key": "training.loop"
                }
              ],
              "next": "f3"
            },
            {
              "id": "scene",
              "text": "Changer de scene",
              "actions": [
                {
                  "type": "switchScene",
                  "scene": "complexe"
                }
              ],
              "next": "f3"
            },
            {
              "id": "nothing",
              "text": "Rien, on continue.",
              "next": "f3"
            }
          ]
        },
        "f3": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Nickel, je reste en support.",
          "next": "fend"
        },
        "fend": {
          "type": "end"
        }
      }
    }
  }
}
