{
  "dialogues": {
    "bloom.intro": {
      "key": "bloom.intro",
      "once": true,
      "startNode": "intro_1",
      "nodes": {
        "intro_1": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Salut. Je suis Bloom, la petite goutte qui va te guider.",
          "next": "intro_2"
