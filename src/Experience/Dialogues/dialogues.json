          "next": "role_choice"
        },
        "role_choice": {
          "type": "choice",
          "speaker": "Bloom",
          "text": "Quelle approche te ressemble le plus ?",
          "choices": [
            {
              "id": "inventeur",
              "text": "J observe, je teste, j invente.",
              "next": "inventeur_reply",
              "conditions": []
            },
            {
              "id": "meneur",
              "text": "Je prends les decisions et je motive.",
              "next": "meneur_reply",
              "conditions": []
            },
            {
              "id": "travailleur",
              "text": "Je fonce et j execute proprement.",
              "next": "travailleur_reply",
              "conditions": []
            },
            {
              "id": "botaniste",
              "text": "Je protege le vivant et je cultive.",
              "next": "botaniste_reply",
              "conditions": []
            }
          ]
        },
        "inventeur_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil inventeur active.",
          "next": "mission_offer"
        },
        "meneur_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil meneur active.",
          "next": "mission_offer"
        },
        "travailleur_reply": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Parfait. Profil travailleur active.",
          "next": "mission_offer"
        },
        "botaniste_reply": {
