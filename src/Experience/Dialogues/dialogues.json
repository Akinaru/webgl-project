          "speaker": "Bloom",
          "text": "Je peux declencher le mini-jeu de calibration. On y va ?",
          "choices": [
            {
              "id": "yes",
              "text": "Oui, lance-le.",
              "next": "mission_yes",
              "conditions": []
            },
            {
              "id": "no",
              "text": "Pas maintenant.",
              "next": "mission_no",
              "conditions": []
            }
          ]
        },
        "mission_yes": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Top. Je te laisse la main, je surveille les variables.",
          "next": "bonus_branch"
        },
        "mission_no": {
          "type": "line",
          "speaker": "Bloom",
          "text": "D accord. On continue la narration tranquille.",
          "next": "bonus_branch"
        },
        "bonus_branch": {
          "type": "branch",
          "branches": [
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "inventeur"
                }
              ],
              "next": "bonus_inventeur"
            },
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "meneur"
                }
              ],
              "next": "bonus_meneur"
            },
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "travailleur"
                }
              ],
              "next": "bonus_travailleur"
            },
            {
              "conditions": [
                {
                  "type": "flagEquals",
                  "key": "bloom_role",
                  "value": "botaniste"
                }
              ],
              "next": "bonus_botaniste"
            }
          ],
          "fallbackNext": "bonus_default"
        },
        "bonus_inventeur": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus inventeur: +1 botaniste pour l equilibre.",
          "next": "end",
          "actions": [
            {
              "type": "addMetier",
              "metier": "BOTANISTE",
              "amount": 1
            }
          ]
        },
        "bonus_meneur": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus meneur: +1 travailleur pour concretiser.",
          "next": "end",
          "actions": [
            {
              "type": "addMetier",
              "metier": "TRAVAILLEUR",
              "amount": 1
            }
          ]
        },
        "bonus_travailleur": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus travailleur: +1 meneur pour la coordination.",
          "next": "end",
          "actions": [
            {
              "type": "addMetier",
              "metier": "MENEUR",
              "amount": 1
            }
          ]
        },
        "bonus_botaniste": {
          "type": "line",
          "speaker": "Bloom",
          "text": "Bonus botaniste: +1 inventeur pour optimiser le vivant.",
          "next": "end",
          "actions": [
            {
              "type": "addMetier",
              "metier": "INVENTEUR",
              "amount": 1
            }
          ]
        },
        "bonus_default": {
          "type": "line",
          "speaker": "Bloom",
          "text": "On garde une base neutre pour le moment.",
          "next": "end"
        },
        "end": {
          "type": "end",
          "actions": [
            {
              "type": "setFlag",
